{
  "name": "cladex",
  "private": true,
  "version": "2.5.6",
  "author": "CLADEX Contributors",
  "license": "MIT",
  "description": "Unified desktop and CLI manager for Codex and Claude Discord relays.",
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite --port=3000 --host=127.0.0.1",
    "server": "node server.cjs",
    "dev:stack": "concurrently \"npm run server\" \"npm run dev\"",
    "start": "npm run app",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "tsc --noEmit",
    "test": "npm run lint && npm run frontend:smoke && npm run api:smoke",
    "api:smoke": "node scripts/server-contract-smoke.cjs",
    "frontend:smoke": "node src/App.workflow.test.mjs",
    "electron": "npm run build && electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://127.0.0.1:3000 && electron . --dev-renderer\"",
    "electron:build": "npm run build && electron-builder --publish never",
    "app": "npm run build && electron ."
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.11.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.cladex.app",
    "productName": "CLADEX",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "server.cjs"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/.pytest_cache/**",
          "!**/tests/**",
          "!**/docs/**",
          "!**/*.egg-info/**",
          "!**/*.pyc",
          "!**/*.pyo"
        ]
      },
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "signAndEditExecutable": false,
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png"
    },
    "icon": "assets/icon.png"
  }
}
